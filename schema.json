{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WikiPerché data",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "label", "items"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "label": { "type": "string", "minLength": 1 },
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "icon", "title", "type", "troubles"],
          "additionalProperties": false,
          "properties": {
            "id":      { "type": "string", "minLength": 1 },
            "icon":    { "type": "string" },
            "title":   { "type": "string", "minLength": 1 },
            "desc":    { "type": "string" },
            "type":    { "type": "string" },
            "troubles":{ "type": "array", "items": { "type": "string" } },
            "link":    { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
